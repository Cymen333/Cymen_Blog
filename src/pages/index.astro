---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import MusicPlayer from '../components/MusicPlayer.astro';

const base = import.meta.env.BASE_URL; // 获取基础路径

const posts = [
  {
    title: "导航【置顶】",
    date: "2026-05-05",
    desc: "按照你的需求，指引你的方向。",
    thumbnail: `${base}images/guide-cover.png`,
    url: `${base}Other/guide`
  },
  {
    title: "Raylib库",
    date: "2026-05-20",
    desc: "讲讲关于raylib库我的看法。", 
    thumbnail: `${base}images/study-cover.png`,
    url: `${base}C&C++/raylib`
  },
  {
    title: "关于C/C++",
    date: "2026-05-17",
    desc: "讲讲关于C/C++我的看法。", 
    thumbnail: `${base}images/study-cover.png`,
    url: `${base}C&C++/aboutC&C++`
  },
  { 
    title: "markdown语法测试",
    date: "2026-05-08",
    desc: "本文章旨在测试MarkDown的显示效果，以作为参考。",
    thumbnail: `${base}images/post-cover.png`,
    url: `${base}Other/markdown`
  }
];
---

<BaseLayout title="Cymen_Blog">
  
  <header class="hero-section">
    <div class="scroll-arrow">↓</div>
  </header>

  <main class="main-container">
    <aside class="sidebar no-scrollbar">
      <div class="card author-card">
        <!-- 头像加上 base -->
        <img class="avatar" src={`${base}images/avatar.png`} alt="头像" />
        <h2>Cymen</h2>
        <p class="bio">I learn, therefore I am.</p>
      </div>

      <MusicPlayer />
    </aside>

    <div class="post-list">
      {posts.map((post) => (
        <article class="card post-card">
          <div class="post-card-content">
            <!-- 文章封面图片和链接 -->
            <img class="post-thumbnail" src={post.thumbnail} alt="配图" />
            <div class="post-text">
              <h2 class="post-title"><a href={post.url}>{post.title}</a></h2>
              <span class="post-date">{post.date}</span>
              <p class="post-desc">{post.desc}</p>
              <a href={post.url} class="read-more">Read More...</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>

<!-- style 保持原样 -->
<style>
  .hero-section { position: relative; height: 100vh; width: 100%; }
  .scroll-arrow { position: absolute; bottom: 40px; left: 50%; font-size: 2.5rem; color: white; text-shadow: 0 2px 4px rgba(0,0,0,0.8); animation: bounce 2s infinite; }
  @keyframes bounce { 0%, 20%, 50%, 80%, 100% { transform: translate(-50%, 0); } 40% { transform: translate(-50%, -20px); } 60% { transform: translate(-50%, -10px); } }

  .main-container { max-width: 1100px; margin: 0 auto 100px auto; padding: 0 20px; display: grid; grid-template-columns: 300px 1fr; gap: 30px; }
  .sidebar { position: sticky; top: 80px; max-height: calc(100vh - 100px); overflow-y: auto; display: flex; flex-direction: column; gap: 20px; }
  
  .author-card { text-align: center; }
  .avatar { width: 100px; height: 100px; border-radius: 50%; border: 3px solid var(--accent-red); margin-bottom: 15px; object-fit: cover;}
  .bio { font-size: 0.9rem; color: var(--text-muted); margin: 15px 0; font-style: italic;}
  
  .post-list { display: flex; flex-direction: column; gap: 25px; }
  .post-card { padding: 0; overflow: hidden; } 
  
  /* 将卡片内容设置为横向 Flex 布局 */
  .post-card-content { 
    display: flex; 
    flex-direction: row; /* 横向排列 */
    align-items: stretch; /* 让图片和文字区域等高 */
  }
  
  /* 左侧图片设置固定宽度 */
  .post-thumbnail { 
    width: 250px; /* 图片宽度，你可以根据喜好调整 */
    min-height: 200px; /* 保证有一个最低高度 */
    object-fit: cover; 
    flex-shrink: 0; /* 防止图片被文字挤压变形 */
    border-right: 1px solid var(--border-color); /* 在图文之间加一条暗线分隔 */
  } 
  
  /* 右侧文字区域占据剩余的所有空间 */
  .post-text { 
    flex: 1; 
    padding: 25px 30px; /* 增加一点内边距让文字更舒展 */
    position: relative; 
    padding-bottom: 60px; /* 给右下角的按钮留出空间 */
    display: flex;
    flex-direction: column;
    justify-content: center; /* 让文字在垂直方向上居中 */
  }
  
  .post-title { font-size: 1.4rem; margin-bottom: 8px; }
  .post-date { font-size: 0.85rem; color: var(--accent-red); }
  .post-desc { margin-top: 15px; line-height: 1.6; color: #ddd;}
  
  .read-more { 
    position: absolute; 
    bottom: 20px; right: 20px; 
    background: rgba(255,255,255,0.1); 
    padding: 5px 15px; 
    border-radius: 15px; 
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }
  .read-more:hover { background: var(--accent-red); color: white;}

  /* --- 手机端响应式适配 --- */
  @media (max-width: 768px) { 
    .main-container { grid-template-columns: 1fr; } 
    .sidebar { position: relative; top: 0; max-height: none; } 
    
    /* 在小屏幕下，恢复为“上图下文” */
    .post-card-content { flex-direction: column; }
    .post-thumbnail { width: 100%; height: 200px; border-right: none; border-bottom: 1px solid var(--border-color); }
    .post-text { padding: 20px; padding-bottom: 50px; }
  }
</style>