---
// src/layouts/PostLayout.astro
import BaseLayout from './BaseLayout.astro';
import MusicPlayer from '../components/MusicPlayer.astro'; 

const { frontmatter } = Astro.props;

// 1. 获取基础路径
const base = import.meta.env.BASE_URL;

// 2. 自动修正封面图路径：如果封面图是本地绝对路径（以 / 开头），就自动加上 base 前缀
let bgImage = frontmatter.cover;
if (bgImage && bgImage.startsWith('/')) {
  // 去掉开头的 '/'，拼接到 base 后面，防止出现双斜杠
  bgImage = base + bgImage.slice(1);
}

// 获取所有文章用于 Wiki 目录
const mdFiles = import.meta.glob('../pages/*.md', { eager: true });
const allPosts = Object.values(mdFiles);

const currentCategory = frontmatter.categories;

const wikiList = allPosts
  .filter((post: any) => post.frontmatter.categories === currentCategory)
  .sort((a: any, b: any) => {
    const markA = a.frontmatter.mark || 999;
    const markB = b.frontmatter.mark || 999;
    return markA - markB;
  });
---

<!-- 3. 将修正后的 bgImage 传给 BaseLayout -->
<BaseLayout title={frontmatter.title} bgImage={bgImage}>
  <div class="post-page-container">
    
    <div class="sidebar-wrapper">
      <aside class="wiki-sidebar card no-scrollbar">
        <h3>[{currentCategory}] 目录</h3>
        <ul class="wiki-list">
          {wikiList.map((post: any) => {
            // 确保目录的链接也自动加上 base（如果 Astro 没自动加的话）
            const postUrl = post.url.startsWith(base) ? post.url : base + post.url.slice(1);
            return (
              <li>
                <a href={postUrl} class={Astro.url.pathname === postUrl || Astro.url.pathname === postUrl + '/' ? 'active' : ''}>
                  <span class="mark-num">{post.frontmatter.mark ? `${post.frontmatter.mark}.` : ''}</span>
                  {post.frontmatter.title}
                </a>
              </li>
            )
          })}
        </ul>
      </aside>

      <div class="post-music">
        <MusicPlayer />
      </div>
    </div>

    <article class="post-content card">
      <header class="post-header">
        <h1>{frontmatter.title}</h1>
        <div class="post-meta">发布于: {frontmatter.date}</div>
      </header>
      <div class="markdown-body">
        <slot />
      </div>
    </article>

  </div>
</BaseLayout>

<style>
  .post-page-container {
    max-width: 1200px; margin: 100px auto 50px auto; padding: 0 20px;
    display: grid; grid-template-columns: 280px 1fr; gap: 30px; align-items: start;
  }
  .sidebar-wrapper {
    position: sticky; top: 80px; display: flex; flex-direction: column; gap: 20px;
    max-height: calc(100vh - 100px);
  }
  .wiki-sidebar { overflow-y: auto; padding: 20px; }
  .post-music { flex-shrink: 0; }

  .wiki-sidebar h3 { margin-bottom: 15px; font-size: 1.1rem; color: var(--accent-red); border-bottom: 1px solid var(--border-color); padding-bottom: 10px; }
  .wiki-list { list-style: none; }
  .wiki-list li { margin-bottom: 5px; }
  .wiki-list a { display: flex; gap: 8px; padding: 8px 10px; border-radius: 6px; transition: 0.2s; color: var(--text-muted); }
  .wiki-list a:hover { background: rgba(255,255,255,0.1); color: white; }
  .wiki-list a.active { background: var(--accent-red); color: white; font-weight: bold; }
  .mark-num { color: inherit; opacity: 0.7; }

  .post-content { padding: 40px; }
  .post-header { margin-bottom: 30px; border-bottom: 1px solid var(--border-color); padding-bottom: 20px; }
  .post-header h1 { font-size: 2.2rem; margin-bottom: 10px; text-shadow: 0 2px 4px rgba(0,0,0,0.5);}
  .post-meta { color: var(--accent-red); font-size: 0.9rem; }

  .markdown-body :global(h2) { margin: 30px 0 15px 0; color: var(--accent-red); }
  .markdown-body :global(p) { margin-bottom: 15px; line-height: 1.8; font-size: 1.05rem; }
  .markdown-body :global(blockquote) {
    border-left: 4px solid var(--accent-red); padding: 10px 15px; margin: 15px 0;
    background: rgba(0, 0, 0, 0.3); color: #ccc; font-style: italic;
  }
  .markdown-body :global(pre) { padding: 15px; border-radius: 8px; overflow-x: auto; margin: 15px 0; background: rgba(0,0,0,0.8); }
  .markdown-body :global(code) { color: var(--accent-red); font-family: monospace; }
</style>