---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
const { title, bgImage = "/images/home-bg.jpg" } = Astro.props; 
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ClientRouter />
    
    <!-- 1. 核心修复：极致防闪烁脚本 -->
    <script is:inline>
      // 这个函数负责把保存的状态应用到 html 标签上
      function applyTheme() {
        const savedState = localStorage.getItem('blogThemeState');
        // 先移除所有可能存在的模式类
        document.documentElement.classList.remove('glass-mode', 'ghost-mode');
        // 如果有保存的状态，重新添加
        if (savedState) {
          document.documentElement.classList.add(savedState);
        }
      }

      // 首次进入页面时执行
      applyTheme();

      // 2. 关键：在 Astro 每次完成页面内容替换（Swap）后，立即重新应用状态
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
  </head>
  <body>
    <div class="global-bg" style={`background-image: url('${bgImage}');`}></div>

    <nav class="top-nav">
      <div class="nav-content">
        <a href="/" class="logo">Cymen的博客</a>
        <div class="menu">
          <a href="/">首页</a>
          <button id="theme-toggle" class="glass-btn">切换界面</button>
        </div>
      </div>
    </nav>

    <slot />

    <script>
      // 3. 按钮点击逻辑：切换并保存状态
      function initThemeButton() {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;

        const states = ['', 'glass-mode', 'ghost-mode'];
        const btnTexts = ['切换: 毛玻璃', '切换: 全透明', '切换: 不透明'];
        
        // 获取当前状态的索引
        let savedState = localStorage.getItem('blogThemeState') || '';
        let currentIndex = states.indexOf(savedState);
        if (currentIndex === -1) currentIndex = 0;
        
        // 初始化按钮文字
        btn.innerText = btnTexts[currentIndex];

        btn.addEventListener('click', () => {
          // 移除旧类名
          if (states[currentIndex]) {
            document.documentElement.classList.remove(states[currentIndex]);
          }
          
          // 计算新索引
          currentIndex = (currentIndex + 1) % 3;
          const newState = states[currentIndex];
          
          // 添加新类名
          if (newState) {
            document.documentElement.classList.add(newState);
          }
          
          // 保存并更新文字
          localStorage.setItem('blogThemeState', newState);
          btn.innerText = btnTexts[currentIndex];
        });
      }

      // 每次页面加载（包括无缝跳转）都要给按钮绑定事件
      document.addEventListener('astro:page-load', initThemeButton);
    </script>
  </body>
</html>

<style>
  /* 你的 CSS 保持不变 ... */
  .global-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-size: cover; background-position: center; z-index: -1; filter: brightness(0.7); transition: background-image 0.5s ease; }
  .top-nav { position: fixed; top: 0; left: 0; width: 100%; height: 60px; background-color: var(--nav-bg); transition: all 0.4s ease; border-bottom: 1px solid var(--border-color); z-index: 1000; }
  .nav-content { max-width: 1200px; margin: 0 auto; height: 100%; display: flex; justify-content: space-between; align-items: center; padding: 0 20px;}
  .logo { font-weight: bold; font-size: 1.2rem; color: var(--accent-red); }
  .menu a { margin-left: 20px; font-weight: 500; }
  .glass-btn { margin-left: 30px; padding: 6px 12px; background: transparent; border: 1px solid var(--accent-red); color: var(--accent-red); border-radius: 20px; cursor: pointer; transition: 0.3s;}
  .glass-btn:hover { background: var(--accent-red); color: #fff; }
</style>