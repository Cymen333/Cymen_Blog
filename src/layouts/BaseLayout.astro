---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
const base = import.meta.env.BASE_URL;
const { title, bgImage = `${base}images/home-bg.jpg` } = Astro.props; 
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ClientRouter />
    
    <script is:inline>
      function applyTheme() {
        const savedState = localStorage.getItem('blogThemeState');
        document.documentElement.classList.remove('glass-mode', 'ghost-mode');
        if (savedState) document.documentElement.classList.add(savedState);
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
  </head>
  <body>
    <div class="global-bg" style={`background-image: url('${bgImage}');`}></div>

    <nav class="top-nav">
      <div class="nav-container">
        <div class="nav-left">
          <a href={base} class="logo">Cymen_Blog</a>
        </div>

        <div class="nav-right">
          <div class="menu">
            <a href={base}>首页</a>
            <a href={`${base}archives`}>归档</a>
            <a href={`${base}about`}>关于</a>
          </div>
          <button id="theme-toggle" class="glass-btn">切换界面</button>
        </div>
      </div>
    </nav>

    <slot />

    <script>
      function initThemeButton() {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        const states = ['', 'glass-mode', 'ghost-mode'];
        const btnTexts = ['切换: 毛玻璃', '切换: 全透明', '切换: 不透明'];
        let savedState = localStorage.getItem('blogThemeState') || '';
        let currentIndex = states.indexOf(savedState);
        if (currentIndex === -1) currentIndex = 0;
        btn.innerText = btnTexts[currentIndex];

        btn.addEventListener('click', () => {
          if (states[currentIndex]) document.documentElement.classList.remove(states[currentIndex]);
          currentIndex = (currentIndex + 1) % 3;
          const newState = states[currentIndex];
          if (newState) document.documentElement.classList.add(newState);
          localStorage.setItem('blogThemeState', newState);
          btn.innerText = btnTexts[currentIndex];
        });
      }
      document.addEventListener('astro:page-load', initThemeButton);
    </script>
  </body>
</html>

<style>
  .global-bg {
    position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
    background-size: cover; background-position: center; z-index: -1;
    filter: brightness(0.7); transition: background-image 0.5s ease;
  }

  .top-nav {
    position: fixed; top: 0; left: 0; width: 100%; height: 60px;
    background-color: var(--nav-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border-bottom: 1px solid var(--border-color);
    z-index: 1000;
    transition: all 0.4s ease;
  }

  .nav-container {
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: space-between; /* 左右对齐 */
    align-items: center;
    padding: 0 40px; /* 侧边间距 */
  }

  .nav-right, .menu { display: flex; align-items: center; gap: 30px; }
  
  .logo { font-weight: bold; font-size: 1.3rem; color: var(--accent-red); letter-spacing: 1px; }

  .menu a { font-weight: 500; font-size: 0.95rem; color: var(--text-main); position: relative; }
  .menu a:hover { color: var(--accent-red); }

  .glass-btn {
    padding: 6px 16px; background: transparent; border: 1px solid var(--accent-red);
    color: var(--accent-red); border-radius: 20px; cursor: pointer; transition: 0.3s;
  }
  .glass-btn:hover { background: var(--accent-red); color: #fff; }

  @media (max-width: 768px) {
    .nav-container { padding: 0 20px; }
    .menu { display: none; } /* 手机端隐藏菜单，或者你可以改为汉堡菜单 */
  }
</style>