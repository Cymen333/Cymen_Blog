---
// src/components/MusicPlayer.astro
const base = import.meta.env.BASE_URL;
---

<div class="card music-card">
  <div class="music-info">
    <!-- transition:persist 保证图片状态在切换页面时不重置 -->
    <img 
      id="disc-img" 
      class="disc-img" 
      src={`${base}images/disc.png`} 
      alt="唱片" 
      transition:persist 
    />
    <div class="track">
      <h4 id="song-name">Nothing</h4>
      <!-- 进度条容器 -->
      <div class="progress-bar" id="progress-container">
        <div id="progress-fill"></div>
      </div>
    </div>
  </div>
  <div class="controls">
    <!-- transition:persist 是音乐不间断的关键 -->
    <audio id="my-audio" src={`${base}music/bgm.mp3`} loop transition:persist></audio>
    <button id="play-btn" class="play-btn">▶</button>
  </div>
</div>

<script>
  // 核心逻辑：封装成一个函数，在每次页面加载时运行
  function setupMusicPlayer() {
    const audio = document.getElementById('my-audio') as HTMLAudioElement;
    const playBtn = document.getElementById('play-btn');
    const discImg = document.getElementById('disc-img');
    const progressContainer = document.getElementById('progress-container');
    const progressFill = document.getElementById('progress-fill');

    if (!audio || !playBtn) return;

    // 1. 同步播放状态（防止跳转页面后按钮显示错误）
    if (!audio.paused) {
      playBtn.innerText = '⏸';
      discImg?.classList.add('playing');
    } else {
      playBtn.innerText = '▶';
      discImg?.classList.remove('playing');
    }

    // 2. 播放/暂停点击事件
    // 注意：先移除旧监听器防止重复绑定（Astro无缝切换常见问题）
    playBtn.onclick = () => {
      if (audio.paused) {
        audio.play();
        playBtn.innerText = '⏸';
        discImg?.classList.add('playing');
      } else {
        audio.pause();
        playBtn.innerText = '▶';
        discImg?.classList.remove('playing');
      }
    };

    // 3. 更新进度条
    audio.ontimeupdate = () => {
      if (audio.duration && progressFill) {
        const percent = (audio.currentTime / audio.duration) * 100;
        progressFill.style.width = percent + '%';
      }
    };

    // 4. 点击进度条跳转音乐进度
    if (progressContainer) {
      progressContainer.onclick = (e) => {
        const width = progressContainer.clientWidth;
        const clickX = e.offsetX;
        const duration = audio.duration;
        audio.currentTime = (clickX / width) * duration;
      };
    }
  }

  // 在首次加载和每次 Astro 页面切换后都运行一次
  document.addEventListener('astro:page-load', setupMusicPlayer);
</script>

<style>
  .music-card { width: 100%; padding: 15px !important; }
  .music-info { display: flex; align-items: center; gap: 15px; margin-bottom: 12px;}
  
  .disc-img { 
    width: 50px; height: 50px; border-radius: 50%; 
    border: 2px solid #333; object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .track { flex: 1; overflow: hidden; }
  .track h4 { font-size: 0.85rem; margin-bottom: 8px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;}
  
  /* 进度条样式 */
  .progress-bar { 
    width: 100%; height: 5px; background: rgba(255,255,255,0.15); 
    border-radius: 10px; cursor: pointer; position: relative; overflow: hidden;
  }
  #progress-fill { 
    width: 0%; height: 100%; background: var(--accent-red); 
    box-shadow: 0 0 10px var(--accent-red);
    transition: width 0.1s linear;
  }
  
  .controls { display: flex; justify-content: center; }
  .play-btn { 
    background: var(--accent-red); border: none; font-size: 1rem; 
    cursor: pointer; color: white; width: 36px; height: 36px; 
    border-radius: 50%; display: flex; align-items: center; 
    justify-content: center; transition: transform 0.2s;
  }
  .play-btn:hover { transform: scale(1.1); }
</style>